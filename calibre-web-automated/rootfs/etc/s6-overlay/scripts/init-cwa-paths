#!/command/with-contenv bashio
# ==============================================================================
# Translate HA add-on options into the paths and env vars CWA expects.
# Runs as a oneshot before upstream's cwa-init service.
# ==============================================================================
set -e

LIBRARY_PATH=$(bashio::config 'library_path')
INGEST_PATH=$(bashio::config 'ingest_path')
CONFIG_PATH=$(bashio::config 'config_path')
PLUGINS_PATH=$(bashio::config 'plugins_path')

# Match the LSIO base's PUID/PGID (set in the Dockerfile) so directories we
# mkdir as root are usable by `abc` after it's remapped.
APP_UID=${PUID:-1000}
APP_GID=${PGID:-1000}

# Re-own only files we created (still root-owned) and tolerate filesystems
# that reject chown (SMB/NFS shares often do): warn and continue rather than
# aborting startup under `set -e`. `--from=0:0` is GNU coreutils, present in
# the LSIO Ubuntu base.
chown_if_root() {
    chown --from=0:0 "$@" 2>/dev/null \
        || bashio::log.warning "chown failed on $* (likely a network share that disallows it; skipping)"
}

bashio::log.info "Configuring CWA paths..."

# Bind-mount the user's chosen path over a target that the upstream image
# expects to find. We use bind mounts (not symlinks) because the targets are
# either Docker VOLUMEs (/config) or pre-populated directories that `ln -sfn`
# refuses to overwrite (e.g. /config/.config/calibre/plugins after the image
# seeds it). Idempotent: inspects /proc/self/mountinfo via findmnt to confirm
# whether target is already bind-mounted from source before mounting.
# Requires privileged: [SYS_ADMIN] + apparmor: false in config.yaml.
bind_user_path() {
    local source=$1 target=$2
    local real_source
    mkdir -p "${source}" "${target}"
    chown_if_root "${APP_UID}:${APP_GID}" "${source}"
    real_source=$(realpath "${source}")
    # Verify target is already bind-mounted from source by inspecting the mount
    # table. stat -c %d only compares device IDs and falsely matches any two
    # directories on the same filesystem, so it cannot confirm the correct source.
    if ! findmnt --noheadings --mountpoint "${target}" \
            --source "${real_source}" > /dev/null 2>&1; then
        mount --bind "${source}" "${target}"
    fi
}

# Validate user-supplied paths up front. library_path and ingest_path are
# required by the schema; config_path and plugins_path are optional. All
# must be absolute since they are used as mkdir / bind-mount sources, and
# config_path must not collide with /config itself.
if ! bashio::var.has_value "${LIBRARY_PATH}"; then
    bashio::exit.nok "library_path must not be empty"
elif [[ "${LIBRARY_PATH}" != /* ]]; then
    bashio::exit.nok "library_path must be an absolute path (got: ${LIBRARY_PATH})"
fi
if ! bashio::var.has_value "${INGEST_PATH}"; then
    bashio::exit.nok "ingest_path must not be empty"
elif [[ "${INGEST_PATH}" != /* ]]; then
    bashio::exit.nok "ingest_path must be an absolute path (got: ${INGEST_PATH})"
fi
if bashio::var.has_value "${CONFIG_PATH}"; then
    if [[ "${CONFIG_PATH}" != /* ]]; then
        bashio::exit.nok "config_path must be an absolute path (got: ${CONFIG_PATH})"
    fi
    # Must not be /config or anything under /config/ to avoid seeding /config
    # onto itself and then removing it.
    if [ "${CONFIG_PATH}" = "/config" ] || [[ "${CONFIG_PATH}" == /config/* ]]; then
        bashio::exit.nok "config_path must not be /config or a path under /config/ (got: ${CONFIG_PATH})"
    fi
fi

# /config: default to /data so persistent state survives add-on upgrades. If
# the user set config_path (e.g. /share/nas/calibre/config), use that so
# /config can live on a network share. Pair a network-share target with
# network_share_mode: true so SQLite WAL is disabled on app.db.
if bashio::var.has_value "${CONFIG_PATH}"; then
    CWA_CONFIG_TARGET="${CONFIG_PATH}"
    bashio::log.info "Using user-provided config_path: ${CWA_CONFIG_TARGET}"
else
    CWA_CONFIG_TARGET="/data"
fi
mkdir -p "${CWA_CONFIG_TARGET}"

# Seed the persistent target from the current contents of /config on first
# use. This must run before the bind mount below: at this point /config is
# the upstream image's default contents (on a brand-new install) or the
# previous bind-mount target (on a later run after switching config_path),
# so the new target gets the right starting state either way. The sentinel
# lives next to the data so a freshly-mounted target is seeded even if
# /data has already been initialized on a previous run.
if ! bashio::fs.file_exists "${CWA_CONFIG_TARGET}/.cwa-initialized"; then
    bashio::log.info "First use of ${CWA_CONFIG_TARGET} — seeding from current /config contents"
    if [ -d /config ] && [ -n "$(ls -A /config 2>/dev/null || true)" ]; then
        cp -an /config/. "${CWA_CONFIG_TARGET}/"
    fi
    touch "${CWA_CONFIG_TARGET}/.cwa-initialized"
    # Seed contents were copied as root; remap to APP_UID:APP_GID so `abc` can
    # read/write its own state. `--from=0:0` skips files the user owns
    # (relevant when migrating an existing install: doc tells users to delete
    # the sentinel after copying their old /config in).
    chown_if_root -R "${APP_UID}:${APP_GID}" "${CWA_CONFIG_TARGET}"
fi
bind_user_path "${CWA_CONFIG_TARGET}" /config

bind_user_path "${LIBRARY_PATH}" /calibre-library
bind_user_path "${INGEST_PATH}" /cwa-book-ingest

mkdir -p /config/.config/calibre
chown_if_root "${APP_UID}:${APP_GID}" /config/.config /config/.config/calibre
if bashio::var.has_value "${PLUGINS_PATH}"; then
    bind_user_path "${PLUGINS_PATH}" /config/.config/calibre/plugins
    if [ ! -f /config/.config/calibre/customize.py.json ]; then
        bashio::log.warning \
            "plugins_path is set but customize.py.json is missing at /config/.config/calibre/. Plugins will not register until you place it there."
    fi
fi

# Surface options as env vars for downstream s6-rc longruns. The /run/s6/container_environment
# directory is read by `with-contenv` for every service started after this oneshot.
mkdir -p /run/s6/container_environment
echo -n "$(bashio::config 'network_share_mode')" > /run/s6/container_environment/NETWORK_SHARE_MODE
echo -n "$(bashio::config 'hardcover_token')"    > /run/s6/container_environment/HARDCOVER_TOKEN
echo -n "$(bashio::config 'trusted_proxy_count')" > /run/s6/container_environment/TRUSTED_PROXY_COUNT
TZ_VALUE=$(bashio::config 'TZ' "$(bashio::supervisor.timezone)")
echo -n "${TZ_VALUE}" > /run/s6/container_environment/TZ

bashio::log.info "CWA paths ready: library=${LIBRARY_PATH}, ingest=${INGEST_PATH}"
